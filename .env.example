# 复制为 .env 后按需修改。缺省值面向本地 docker-compose。
HTTP_ADDR=:8888

MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/vibe_studio?charset=utf8mb4&parseTime=True&loc=Local

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vibe-studio

# GitHub OAuth（个人免费：https://github.com/settings/developers → New OAuth App）
# Authorization callback URL 必须填成下面的 OAUTH_GITHUB_REDIRECT_URL
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8888/api/v1/auth/oauth/github/callback
FRONTEND_URL=http://localhost:5173
